# DUAL Protocol Configuration
# Set DUAL_CONFIGURED=true to enable real DUAL API integration
DUAL_CONFIGURED=false
DUAL_API_URL=https://api.dual.io
DUAL_API_KEY=your-api-key-here
DUAL_ORG_ID=your-org-id
DUAL_TEMPLATE_ID=your-template-id
DUAL_WEBHOOK_SECRET=your-webhook-secret
DUAL_WEBHOOK_CALLBACK_URL=http://localhost:3000/api/webhooks

# Database Configuration
# Uses SQLite by default. Format: file:./path/to/db.sqlite
DATABASE_URL=file:./dev.db

# Application
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development
